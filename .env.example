# ============================================================
# YUMMY — Environment Configuration
# Copy this file to .env and fill in your values.
#
# SECURITY NOTES:
#   - Never commit .env to version control (it's in .gitignore)
#   - Keys set here are loaded at startup and never returned by the API
#   - You can also set keys at runtime via the Settings panel in the UI
#   - Runtime UI values take precedence over ENV values after being saved
# ============================================================

# ── Active AI Provider ────────────────────────────────────────────────────────
# Options: openai | gemini | bedrock | copilot | ollama
AI_PROVIDER=openai

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-09-2025

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# IAM user needs bedrock:InvokeModel permission.
# Enable model access in the AWS console before use.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── GitHub Copilot ────────────────────────────────────────────────────────────
# Token needs the 'copilot' scope. Requires an active Copilot subscription.
COPILOT_GITHUB_TOKEN=
COPILOT_MODEL=gpt-4o

# ── Ollama (Local, no API key needed) ─────────────────────────────────────────
# Run: ollama serve && ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── GitHub Repo (for scanning) ────────────────────────────────────────────────
# Optional: set a default repo so you don't need to run /setup every time.
# GITHUB_TOKEN is only needed for private repos (Contents: Read scope).
# GITHUB_REPO_URL=https://github.com/owner/repo
# GITHUB_TOKEN=ghp_...

# ── Server Ports ──────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Split deploy (browser → API) ─────────────────────────────────────────────
# Frontend build-time: set in hosting / Docker build-arg NEXT_PUBLIC_API_URL
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#
# Backend: origins allowed for browser requests (comma-separated)
# CORS_ORIGINS=https://app.yourdomain.com
