# ============================================================
# YUMMY — Cấu hình chung cho cả Frontend + Backend
# Copy file này thành .env rồi điền giá trị
# ============================================================

# --- AI Provider ---
AI_PROVIDER=gemini                      # "gemini" hoặc "ollama"

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here # https://aistudio.google.com/app/apikey

# --- Ollama (nếu AI_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama

# --- GitHub (optional, cần cho private repo) ---
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# --- Ports (thay nếu bị conflict) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
