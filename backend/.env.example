# ============================================================
# YUMMY Backend — Environment Variables
# Copy file này thành .env và điền giá trị
# ============================================================

# AI Provider: "gemini" hoặc "ollama"
AI_PROVIDER=gemini

# Gemini API Key (lấy tại https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Local Config (dùng khi AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama

# GitHub Token (optional, cần cho private repo)
# Lấy tại: https://github.com/settings/tokens → Fine-grained token
# Permissions cần: Contents (read), Metadata (read)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
